# MySQL example for Hostinger:
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://cloudview_user:strong_password@localhost:3306/cloudview"

# Use a long random value. Example: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL used for NFC and QR generation
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: used by mock POS logs
MOCK_POS_SHARED_SECRET="dev-pos-secret"
