DATABASE_URL="mysql://cloudview_user:strong_password@localhost:3306/cloudview"
AUTH_SECRET="replace-with-a-long-random-secret"

# Public application URLs.
APP_URL=https://careerinfoph.com
NEXT_PUBLIC_APP_URL=https://careerinfoph.com
NEXT_PUBLIC_LAN_IP=https://careerinfoph.com
NEXT_PUBLIC_FORCE_HTTPS=false
POS_XENDIT_RETURN_URL=https://careerinfoph.com

ALLOWED_DEV_ORIGINS=https://careerinfoph.com
SERVER_ACTION_ALLOWED_ORIGINS=https://careerinfoph.com

MOCK_POS_SHARED_SECRET=replace-with-a-random-development-secret
NFC_ACCESS_TTL_MINUTES=720
NFC_IDLE_TIMEOUT_MINUTES=360

NEXT_PUBLIC_CENTRIFUGO_HOST=https://careerinfoph.com
NEXT_PUBLIC_CENTRIFUGO_PORT=8000
NEXT_PUBLIC_CENTRIFUGO_PATH=/connection/websocket
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://careerinfoph.com:8000/connection/websocket
CENTRIFUGO_TOKEN_HMAC_SECRET=replace-with-a-long-random-secret
CENTRIFUGO_API_URL=http://127.0.0.1:8000/api
CENTRIFUGO_API_KEY=replace-with-a-random-api-key
CENTRIFUGO_HTTP_API_URL=http://127.0.0.1:8000/api
CENTRIFUGO_HTTP_API_KEY=replace-with-a-random-api-key

SCHEDULED_RELEASE_CRON_SECRET=replace-with-a-long-random-secret
SCHEDULED_RELEASE_INTERVAL_MS=60000

# Server-only Xendit credentials. Never expose these through NEXT_PUBLIC_*.
XENDIT_SECRET_KEY=xnd_development_replace_me
XENDIT_WEBHOOK_TOKEN=replace-with-the-token-from-xendit-webhook-settings
XENDIT_LIVEMODE=false

# Optional hosted-checkout channel restrictions. Leave empty to show every
# compatible channel activated on the Xendit account.
# Supported explicit values in this implementation:
# CARDS,GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA
XENDIT_PAYMENT_METHODS=CARDS,GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA
XENDIT_GUEST_PAYMENT_METHODS=GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA

# CloudView master Business ID (24 hexadecimal characters) for xenPlatform.
# xenPlatform sub-accounts and Split Payments must be enabled by Xendit first.
XENDIT_MASTER_ACCOUNT_ID=5f27a14a9bf05c73dd040bc8

# Automatic refund/retry behavior.
XENDIT_AUTO_REFUND_ON_FULFILLMENT_FAILURE=true
XENDIT_REFUND_CRON_SECRET=replace-with-a-long-random-secret
