# Server-only Xendit credentials. Never expose these through NEXT_PUBLIC_*.
XENDIT_SECRET_KEY=xnd_development_yHPiSPhUbKENvs4wOzthsU5ZKU4sqqlTfo3vIarhok7kHtiZmBEA0GAOEDxoNgv

XENDIT_WEBHOOK_TOKEN=LzTXcbZzhISzl2VQUpDmFNkHIPPTGQr9I7JWJqUEAszKUHA6
XENDIT_LIVEMODE=false

# Optional hosted-checkout channel restrictions. Leave empty to show every
# compatible channel activated on the Xendit account.
# Supported explicit values in this implementation:
# CARDS,GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA
XENDIT_PAYMENT_METHODS=CARDS,GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA
XENDIT_GUEST_PAYMENT_METHODS=GCASH,QRPH,SHOPEEPAY,GRABPAY,PAYMAYA

# CloudView master Business ID (24 hexadecimal characters) for xenPlatform.
# xenPlatform sub-accounts and Split Payments must be enabled by Xendit first.
