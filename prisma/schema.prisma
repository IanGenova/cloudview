enum MenuStockMovementType {
  SET_OPENING
  ADD
  REMOVE
  SALE
  CANCEL_RESTORE
  SOLD_OUT
  REOPEN
}

model MenuDailyStock {
  id        String   @id @default(cuid())
  hotelId   String
  productId String
  stockDate DateTime

  openingQty   Int     @default(0)
  availableQty Int     @default(0)
  soldQty      Int     @default(0)
  isSoldOut    Boolean @default(false)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel     Hotel                    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  product   MenuProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements MenuDailyStockMovement[]

  @@unique([hotelId, productId, stockDate])
  @@index([hotelId])
  @@index([productId])
  @@index([stockDate])
  @@index([isSoldOut])
}

model MenuDailyStockMovement {
  id        String   @id @default(cuid())
  hotelId   String
  productId String
  stockId   String
  stockDate DateTime

