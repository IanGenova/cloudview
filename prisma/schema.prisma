model GuestMember {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  birthDate DateTime?

  isActive Boolean @default(true)

  pointAccount    GuestPointAccount?
  pointLedger     GuestPointLedger[]
  redemptions     RewardRedemption[]
  orders          Order[]
  nfcSessions     NfcGuestSession[]
  serviceRequests ServiceRequest[]
  guestStays      GuestStay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
  @@index([phone])
  @@index([email])
}

model GuestStay {
  id String @id @default(cuid())

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  guestMemberId String
  guestMember   GuestMember @relation(fields: [guestMemberId], references: [id], onDelete: Cascade)

  passcodeHash      String
  passcodeEncrypted String? @db.Text
  maxDevices        Int     @default(2)

  status GuestStayStatus @default(ACTIVE)

  checkInAt          DateTime  @default(now())
  expectedCheckOutAt DateTime?
  checkedOutAt       DateTime?

  checkoutFoodTotalCents    Int @default(0)
  checkoutServiceTotalCents Int @default(0)
  checkoutManualChargeCents Int @default(0)
  checkoutDiscountCents     Int @default(0)
  checkoutSubtotalCents     Int @default(0)
  checkoutPaymentCents      Int @default(0)
  checkoutBalanceDueCents   Int @default(0)

  checkoutPaymentMethod    GuestStayCheckoutPaymentMethod?
  checkoutPaymentReference String?                         @db.VarChar(160)
  checkoutPaymentNote      String?                         @db.Text
  checkoutManualChargeNote String?                         @db.Text
  checkoutDiscountNote     String?                         @db.Text
  checkoutSnapshot         Json?

  checkedOutById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices          GuestStayDevice[]
  nfcGuestSessions NfcGuestSession[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  pointLedgers     GuestPointLedger[]
  folio            GuestStayFolio?
  folioLines       GuestStayFolioLine[]
  folioPayments    GuestStayFolioPayment[]

  @@index([hotelId])
  @@index([roomId])
  @@index([guestMemberId])
  @@index([status])
  @@index([checkInAt])
  @@index([expectedCheckOutAt])
  @@index([checkedOutAt])
  @@index([checkedOutById])
}

model GuestStayFolio {
  id String @id @default(cuid())

  folioNumber String @unique @db.VarChar(40)

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestStayId String    @unique
  guestStay   GuestStay @relation(fields: [guestStayId], references: [id], onDelete: Cascade)

  status GuestStayFolioStatus @default(OPEN)

  openedAt DateTime  @default(now())
  closedAt DateTime?

  receiptPrintedAt  DateTime?
  receiptPrintCount Int       @default(0)

  guestSnapshot    Json?
  checkoutSnapshot Json?

  foodTotalCents    Int @default(0)
  serviceTotalCents Int @default(0)
  manualChargeCents Int @default(0)
  discountCents     Int @default(0)
  subtotalCents     Int @default(0)
  paidCents         Int @default(0)
  balanceDueCents   Int @default(0)

  createdById String?
  createdBy   User?   @relation("GuestStayFolioCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  closedById String?
  closedBy   User?   @relation("GuestStayFolioClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  lines    GuestStayFolioLine[]
  payments GuestStayFolioPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
  @@index([guestStayId])
  @@index([status])
  @@index([closedAt])
  @@index([createdById])
  @@index([closedById])
}

model GuestStayFolioLine {
  id String @id @default(cuid())

  folioId String
  folio   GuestStayFolio @relation(fields: [folioId], references: [id], onDelete: Cascade)

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestStayId String
  guestStay   GuestStay @relation(fields: [guestStayId], references: [id], onDelete: Cascade)

  lineType   GuestStayFolioLineType
  lineStatus GuestStayFolioLineStatus @default(POSTED)

  sourceOrderId String?
  sourceOrder   Order?  @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)

  sourceRoomAddOnChargeId String?
  sourceRoomAddOnCharge   RoomAddOnCharge? @relation(fields: [sourceRoomAddOnChargeId], references: [id], onDelete: SetNull)

  title       String  @db.VarChar(180)
  description String? @db.Text

  quantity        Int @default(1)
  unitAmountCents Int @default(0)
  amountCents     Int @default(0)

  metadata Json?

  postedById String?
  postedBy   User?   @relation("GuestStayFolioLinePostedBy", fields: [postedById], references: [id], onDelete: SetNull)

  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folioId])
  @@index([hotelId])
  @@index([guestStayId])
  @@index([lineType])
  @@index([lineStatus])
  @@index([sourceOrderId])
  @@index([sourceRoomAddOnChargeId])
  @@index([postedById])
  @@index([postedAt])
}

model GuestStayFolioPayment {
  id String @id @default(cuid())

  folioId String
  folio   GuestStayFolio @relation(fields: [folioId], references: [id], onDelete: Cascade)

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestStayId String
  guestStay   GuestStay @relation(fields: [guestStayId], references: [id], onDelete: Cascade)

  paymentMethod GuestStayCheckoutPaymentMethod
  paymentStatus GuestStayFolioPaymentStatus    @default(POSTED)

  amountCents Int

  reference String? @db.VarChar(160)
  note      String? @db.Text

  receivedById String?
  receivedBy   User?   @relation("GuestStayFolioPaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  paidAt   DateTime  @default(now())
  voidedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folioId])
  @@index([hotelId])
  @@index([guestStayId])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([receivedById])
  @@index([paidAt])
}

model GuestStayDevice {
  id String @id @default(cuid())

  guestStayId String
  guestStay   GuestStay @relation(fields: [guestStayId], references: [id], onDelete: Cascade)

  deviceTokenHash String
  userAgentHash   String?

  deviceLabel String?

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?

  @@unique([guestStayId, deviceTokenHash])
  @@index([guestStayId])
  @@index([revokedAt])
}

model GuestPointAccount {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestMemberId String      @unique
  guestMember   GuestMember @relation(fields: [guestMemberId], references: [id], onDelete: Cascade)

  availablePoints        Int @default(0)
  pendingPoints          Int @default(0)
  lifetimeEarnedPoints   Int @default(0)
  lifetimeRedeemedPoints Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
}

model GuestPointLedger {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestMemberId String
  guestMember   GuestMember @relation(fields: [guestMemberId], references: [id], onDelete: Cascade)

  type   GuestPointLedgerType
  status GuestPointLedgerStatus @default(CONFIRMED)

  points Int

  source      String
  referenceId String?
  description String?

  createdById String?
  createdBy   User?   @relation("GuestPointLedgerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  guestStayId String?
  guestStay   GuestStay? @relation(fields: [guestStayId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([hotelId, type, source, referenceId])
  @@index([hotelId])
  @@index([guestMemberId])
  @@index([guestStayId])
  @@index([source])
  @@index([referenceId])
}

model Reward {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  pointsCost Int
  rewardType RewardType @default(DISCOUNT_AMOUNT)

  discountCents   Int?
  discountPercent Int?
  freeProductId   String?

  isActive Boolean @default(true)

  validFrom  DateTime?
  validUntil DateTime?

  redemptions RewardRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
}

model RewardRedemption {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  guestMemberId String
  guestMember   GuestMember @relation(fields: [guestMemberId], references: [id], onDelete: Cascade)

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  pointsUsed Int
  code       String @unique

  status RewardRedemptionStatus @default(RESERVED)

  orderId String?

  redeemedAt  DateTime  @default(now())
  usedAt      DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
  @@index([guestMemberId])
  @@index([rewardId])
}

model GuestPointSettings {
  id      String @id @default(cuid())
  hotelId String @unique
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  // Example: 10000 cents = ₱100 = 1 point
  spendCentsPerPoint Int @default(10000)

  minimumSpendCents Int @default(0)

  redemptionEnabled Boolean @default(true)

  // NFC engagement rewards
  nfcTapPoints        Int     @default(1)
  nfcDailyMaxPoints   Int     @default(3)
  nfcOncePerTagPerDay Boolean @default(true)

  // Service request rewards
  serviceRequestCompletionPoints Int @default(1)
  serviceRequestDailyMaxPoints   Int @default(3)

  guestStayCheckInEnabled Boolean @default(true)
  guestStayCheckInPoints  Int     @default(10)

  pointsExpirationDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DashboardNotification {
  id String @id @default(cuid())

  hotelId String?
  userId  String?

  type    String  @db.VarChar(80)
  title   String  @db.VarChar(180)
  message String  @db.Text
  url     String? @db.VarChar(300)

  payload Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId, isRead, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([type])
}

enum POSPayMongoStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
  PAID_REVIEW_REQUIRED
}

model PosPayMongoSession {
  id                  String            @id @default(cuid())
  hotelId             String
  createdById         String
  checkoutSessionId   String?           @unique
  checkoutUrl         String?           @db.Text
  amountCents         Int
  currency            String            @default("PHP") @db.VarChar(3)
  payload             Json
  status              POSPayMongoStatus @default(PENDING)
  paymongoPaymentId   String?           @db.VarChar(191)
  orderCode           String?           @db.VarChar(191)
  serviceRequestCodes Json?
  errorMessage        String?           @db.Text
  paidAt              DateTime?
  processingStartedAt DateTime?
  completedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([hotelId, status])
  @@index([createdById, createdAt])
