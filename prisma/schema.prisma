generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  
}

enum Role {
  SUPER_ADMIN
  HOTEL_ADMIN
  STAFF
  KITCHEN
}

enum ServiceBillingMode {
  FREE
  FIXED_PRICE
  PRICE_ON_CONFIRMATION
}

enum TagType {
  ROOM
  POOL
  RESTAURANT
  LOBBY
  AMENITY
  SPA
  PARKING
  GYM
  BAR
  OTHER
}

enum TagStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  ROOM_CHARGE
  PAY_AT_COUNTER
  CASH
  POS
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum ServiceRequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  ORDER_DEDUCTION
}

enum PosSyncStatus {
  PENDING
  SENT
  FAILED
  RETRY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum MenuProductType {
  SINGLE
  BUNDLE
}

enum OrderItemStatus {
  ACTIVE
  PARTIALLY_CANCELLED
  CANCELLED
}

enum DashboardModule {
  OVERVIEW
  HOTELS
  HOTEL_GUIDE
  ROOMS_LOCATIONS
  NFC_TAGS
  MENU
  INVENTORY
  ORDERS
  KITCHEN_DISPLAY
  SERVICES_MODULE
  SERVICE_REQUESTS
  POS_TERMINAL
  ANALYTICS
  HOTEL_SETTINGS
  USER_ACCOUNT_SETTINGS
}

model UserDashboardPermission {
  id        String          @id @default(cuid())
  userId    String
  module    DashboardModule

  canView   Boolean         @default(false)
  canCreate Boolean         @default(false)
  canEdit   Boolean         @default(false)
  canDelete Boolean         @default(false)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@index([module])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  hotelId      String?
  hotel        Hotel?   @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedServiceRequests ServiceRequest[]              @relation("AssignedRequests")
  orderStatusUpdates      OrderStatusHistory[]
  serviceStatusUpdates    ServiceRequestStatusHistory[]
  inventoryMovements      InventoryMovement[]
  activityLogs            ActivityLog[]
  dashboardPermissions UserDashboardPermission[]

  @@index([hotelId])
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  brandColor  String   @default("#111111")
  accentColor String   @default("#B88938")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings                     HotelSettings?
  users                        User[]
  rooms                        Room[]
  locations                    Location[]
  nfcTags                      NfcTag[]
  menuCategories               MenuCategory[]
  menuProducts                 MenuProduct[]
  inventoryItems               InventoryItem[]
  inventoryMovements           InventoryMovement[]
  orders                       Order[]
  serviceRequests              ServiceRequest[]
  posIntegration               PosIntegration?
  activityLogs                 ActivityLog[]
  nfcAccessSessions            NfcAccessSession[]
  subscription                 HotelSubscription?
  serviceCatalogItems          ServiceCatalogItem[]
  guideSections                HotelGuideSection[]
  guideItems                   HotelGuideItem[]
  menuDailyStocks              MenuDailyStock[]
  menuDailyStockMovements      MenuDailyStockMovement[]
  menuAvailabilityStocks       MenuAvailabilityStock[]
  menuAvailabilityMovements    MenuAvailabilityMovement[]
  menuBundleComponents         MenuBundleComponent[]
  serviceAvailabilityStocks    ServiceAvailabilityStock[]
  serviceAvailabilityMovements ServiceAvailabilityMovement[]

  guideImages      HotelGuideImage[]
  nfcGuestSessions NfcGuestSession[]
}

model HotelSettings {
  id                String   @id @default(cuid())
  hotelId           String   @unique
  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  currency          String   @default("PHP")
  taxRate           Decimal  @default(0.00) @db.Decimal(6, 4)
  serviceChargeRate Decimal  @default(0.00) @db.Decimal(6, 4)
  wifiName          String?
  wifiPassword      String?
  checkInTime       String   @default("2:00 PM")
  checkOutTime      String   @default("12:00 PM")
  poolHours         String   @default("7:00 AM - 9:00 PM")
  poolRules         String?  @db.Text
  policies          String?  @db.Text
  guideText         String?  @db.Text
  contactPhone      String?
  contactEmail      String?
  guestPortalHeroImageUrl String? @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Room {
  id        String    @id @default(cuid())
  hotelId   String
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  number    String
  floor     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  nfcTags          NfcTag[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  nfcGuestSessions NfcGuestSession[]

  @@unique([hotelId, number])
  @@index([hotelId])
}

model Location {
  id          String    @id @default(cuid())
  hotelId     String
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  type        TagType
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  nfcTags          NfcTag[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  nfcGuestSessions NfcGuestSession[]

  @@index([hotelId])
}

model NfcTag {
  id            String    @id @default(cuid())
  hotelId       String
  hotel         Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  code          String    @unique
  label         String
  tagType       TagType
  status        TagStatus @default(ACTIVE)
  roomId        String?
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scanSecret    String?   @unique
  lastScannedAt DateTime?
  deletedAt     DateTime?

  accessSessions NfcAccessSession[]

  orders          Order[]
  serviceRequests ServiceRequest[]
  guestSessions   NfcGuestSession[]

  @@index([hotelId])
  @@index([roomId])
  @@index([locationId])
}

model MenuCategory {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MenuProduct[]

  @@index([hotelId])
}

model MenuProduct {
  id         String       @id @default(cuid())
  hotelId    String
  hotel      Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  categoryId String
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name            String
  description     String? @db.Text
  priceCents      Int
  imageUrl        String?
  isAvailable     Boolean @default(true)
  prepTimeMinutes Int     @default(10)

  productType MenuProductType @default(SINGLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     ProductImage[]
  recipes    ProductInventoryRecipe[]
  orderItems OrderItem[]

  dailyStocks         MenuDailyStock[]
  dailyStockMovements MenuDailyStockMovement[]

  availabilityStocks    MenuAvailabilityStock[]
  availabilityMovements MenuAvailabilityMovement[]

  bundleComponents MenuBundleComponent[] @relation("BundleProduct")
  usedInBundles    MenuBundleComponent[] @relation("BundleComponentProduct")

  orderBundleProducts          OrderItemBundleComponent[] @relation("OrderBundleProduct")
  orderBundleComponentProducts OrderItemBundleComponent[] @relation("OrderBundleComponentProduct")

  @@index([hotelId])
  @@index([categoryId])
  @@index([productType])
}

model MenuBundleComponent {
  id                 String @id @default(cuid())
  hotelId            String
  bundleProductId    String
  componentProductId String
  quantity           Int    @default(1)
  sortOrder          Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel            Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bundleProduct    MenuProduct @relation("BundleProduct", fields: [bundleProductId], references: [id], onDelete: Cascade)
  componentProduct MenuProduct @relation("BundleComponentProduct", fields: [componentProductId], references: [id], onDelete: Cascade)

  @@unique([bundleProductId, componentProductId])
  @@index([hotelId])
  @@index([bundleProductId])
  @@index([componentProductId])
}

model ProductImage {
  id        String      @id @default(cuid())
  productId String
  product   MenuProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
}

model InventoryItem {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  unit          String
  stockQuantity Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel  Decimal  @default(0) @db.Decimal(12, 3)
  supplier      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements InventoryMovement[]
  recipes   ProductInventoryRecipe[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  hotelId   String
  hotel     Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  itemId    String
  item      InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Decimal               @db.Decimal(12, 3)
  reason    String?
  orderId   String?
  order     Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime              @default(now())

  @@index([hotelId])
  @@index([itemId])
  @@index([orderId])
}

enum ServiceAvailabilityMovementType {
  SET_STOCK
  ADD_STOCK
  REMOVE_STOCK
  SOLD_OUT
  REOPEN
  REQUEST_DEDUCTION
  CANCEL_RESTORE
}

model ProductInventoryRecipe {
  id              String        @id @default(cuid())
  productId       String
  product         MenuProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Decimal       @db.Decimal(12, 3)

  @@unique([productId, inventoryItemId])
}

model Order {
  id                  String        @id @default(cuid())
  hotelId             String
  hotel               Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId              String?
  room                Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId          String?
  location            Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tagId               String?
  tag                 NfcTag?       @relation(fields: [tagId], references: [id], onDelete: SetNull)
  orderCode           String        @unique
  guestName           String?
  notes               String?       @db.Text
  paymentMethod       PaymentMethod @default(ROOM_CHARGE)
  paymentStatus       PaymentStatus @default(UNPAID)
  status              OrderStatus   @default(PENDING)
  subtotalCents       Int
  serviceChargeCents  Int           @default(0)
  taxCents            Int           @default(0)
  totalCents          Int
  posSyncStatus       PosSyncStatus @default(PENDING)
  inventoryDeductedAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  posLogs            PosSyncLog[]
  inventoryMovements InventoryMovement[]
  guestSessionId     String?
  guestSession       NfcGuestSession?     @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  @@index([guestSessionId])
  @@index([hotelId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   MenuProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productNameSnapshot String
  quantity            Int
  unitPriceCents      Int
  notes               String? @db.Text

  isBundleSnapshot Boolean @default(false)

  createdAt DateTime @default(now())

  bundleComponents OrderItemBundleComponent[]
  status           OrderItemStatus            @default(ACTIVE)
  cancelledQty     Int                        @default(0)
  cancelledAt      DateTime?
  cancelReason     String?
  cancelledById    String?

  @@index([orderId])
  @@index([productId])
  @@index([isBundleSnapshot])
}

model OrderItemBundleComponent {
  id          String @id @default(cuid())
  orderItemId String

  bundleProductId    String?
  componentProductId String?

  componentNameSnapshot String
  quantity              Int

  createdAt DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  bundleProduct MenuProduct? @relation("OrderBundleProduct", fields: [bundleProductId], references: [id], onDelete: SetNull)

  componentProduct MenuProduct? @relation("OrderBundleComponentProduct", fields: [componentProductId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([bundleProductId])
  @@index([componentProductId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model ServiceRequest {
  id            String               @id @default(cuid())
  hotelId       String
  hotel         Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId        String?
  room          Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId    String?
  location      Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tagId         String?
  tag           NfcTag?              @relation(fields: [tagId], references: [id], onDelete: SetNull)
  requestCode   String
  type          String
  guestName     String?
  notes         String?              @db.Text
  status        ServiceRequestStatus @default(NEW)
  assignedToId  String?
  assignedTo    User?                @relation("AssignedRequests", fields: [assignedToId], references: [id], onDelete: SetNull)
  quantity      Int                  @default(1)
  cancelledQty  Int                  @default(0)
  cancelledAt   DateTime?
  cancelReason  String?
  cancelledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory  ServiceRequestStatusHistory[]
  guestSessionId String?
  guestSession   NfcGuestSession?              @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  @@index([guestSessionId])
  @@index([hotelId])
  @@index([status])
  @@index([requestCode])
  @@index([hotelId, requestCode])
}

model ServiceRequestStatusHistory {
  id        String               @id @default(cuid())
  requestId String
  request   ServiceRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status    ServiceRequestStatus
  note      String?
  userId    String?
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime             @default(now())

  @@index([requestId])
}

model PosIntegration {
  id              String   @id @default(cuid())
  hotelId         String   @unique
  hotel           Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  providerName    String   @default("Mock POS")
  apiEndpoint     String?
  apiKeyEncrypted String?
  webhookSecret   String?
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs PosSyncLog[]
}

model PosSyncLog {
  id              String        @id @default(cuid())
  hotelId         String
  orderId         String
  integrationId   String?
  status          PosSyncStatus
  requestPayload  Json?
  responsePayload Json?
  error           String?       @db.Text
  createdAt       DateTime      @default(now())

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  integration PosIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  hotelId   String?
  hotel     Hotel?   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actor     String?
  action    String
  entity    String
  entityId  String?
  message   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([hotelId])
  @@index([createdAt])
}

model SubscriptionPackage {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  priceCents  Int
  maxHotels   Int      @default(1)
  maxRooms    Int      @default(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions HotelSubscription[]
}

model HotelSubscription {
  id        String              @id @default(cuid())
  hotelId   String              @unique
  hotel     Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  packageId String
  package   SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  status    SubscriptionStatus  @default(TRIALING)
  startedAt DateTime            @default(now())
  endsAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model NfcAccessSession {
  id            String  @id @default(cuid())
  tagId         String
  hotelId       String
  tokenHash     String  @unique
  userAgentHash String?
  ipHash        String?

  expiresAt     DateTime
  idleExpiresAt DateTime?
  lastSeenAt    DateTime?

  revokedAt DateTime?
  createdAt DateTime  @default(now())

  tag   NfcTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  hotel Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@index([hotelId])
  @@index([expiresAt])
  @@index([idleExpiresAt])
}

model NfcGuestSession {
  id         String  @id @default(cuid())
  sessionKey String  @unique
  hotelId    String
  tagId      String
  roomId     String?
  locationId String?

  startedAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  endedAt    DateTime?

  hotel    Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  tag      NfcTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  room     Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  orders          Order[]
  serviceRequests ServiceRequest[]

  @@index([hotelId])
  @@index([tagId])
  @@index([roomId])
  @@index([locationId])
  @@index([startedAt])
}

model RoomAddOnCharge {
  id               String @id @default(cuid())
  chargeCode       String @unique
  hotelId          String
  roomId           String
  serviceRequestId String @unique

  itemName    String
  description String?
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  postedById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hotelId])
  @@index([roomId])
  @@index([serviceRequestId])
}

enum RoomAddOnPaymentStatus {
  UNPAID
  PAID
  VOIDED
}

model ServiceCatalogItem {
  id          String  @id @default(cuid())
  hotelId     String
  code        String
  name        String
  category    String
  description String?
  iconKey     String  @default("ConciergeBell")

  billingMode ServiceBillingMode @default(FREE)
  unitPrice   Decimal            @default(0) @db.Decimal(10, 2)
  unitLabel   String?

  inventoryTracked Boolean @default(false)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  availabilityStock     ServiceAvailabilityStock?
  availabilityMovements ServiceAvailabilityMovement[]

  @@unique([hotelId, code])
  @@index([hotelId])
  @@index([category])
  @@index([isActive])
}

enum HotelGuideItemType {
  INFORMATION
  QUICK_ACTION
  POLICY
  CONTACT
  LOCATION
  FACILITY
  DINING
  TRANSPORTATION
  FAQ
}

model HotelGuideSection {
  id      String @id @default(cuid())
  hotelId String

  title       String
  subtitle    String?
  description String?
  imageUrl    String? @db.Text
  iconKey     String  @default("Info")

  panoramaEnabled  Boolean @default(false)
  panoramaImageUrl String? @db.Text

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel         Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  items         HotelGuideItem[]
  galleryImages HotelGuideImage[]

  @@index([hotelId])
  @@index([isActive])
  @@index([sortOrder])
}

model HotelGuideItem {
  id        String @id @default(cuid())
  sectionId String
  hotelId   String

  title    String
  subtitle String?
  content  String?
  itemType HotelGuideItemType @default(INFORMATION)

  imageUrl String? @db.Text
  iconKey  String  @default("Info")

  panoramaEnabled  Boolean @default(false)
  panoramaImageUrl String? @db.Text

  hours    String?
  location String?
  contact  String?
  mapUrl   String?

  buttonLabel String?
  buttonHref  String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel         Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  section       HotelGuideSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  galleryImages HotelGuideImage[]

  @@index([hotelId])
  @@index([sectionId])
  @@index([itemType])
  @@index([isActive])
  @@index([sortOrder])
}

model HotelGuideImage {
  id        String  @id @default(cuid())
  hotelId   String
  sectionId String?
  itemId    String?

  title    String?
  caption  String?
  imageUrl String  @db.Text

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel   Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  section HotelGuideSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  item    HotelGuideItem?    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([sectionId])
  @@index([itemId])
  @@index([isActive])
  @@index([sortOrder])
}

enum MenuStockMovementType {
  SET_OPENING
  ADD
  REMOVE
  SALE
  CANCEL_RESTORE
  SOLD_OUT
  REOPEN
}

model MenuDailyStock {
  id        String   @id @default(cuid())
  hotelId   String
  productId String
  stockDate DateTime

  openingQty   Int     @default(0)
  availableQty Int     @default(0)
  soldQty      Int     @default(0)
  isSoldOut    Boolean @default(false)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel     Hotel                    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  product   MenuProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements MenuDailyStockMovement[]

  @@unique([hotelId, productId, stockDate])
  @@index([hotelId])
  @@index([productId])
  @@index([stockDate])
  @@index([isSoldOut])
}

model MenuDailyStockMovement {
  id        String   @id @default(cuid())
  hotelId   String
  productId String
  stockId   String
  stockDate DateTime

  type     MenuStockMovementType
  quantity Int
  reason   String?
  userId   String?

  createdAt DateTime @default(now())

  hotel   Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  product MenuProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock   MenuDailyStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([productId])
  @@index([stockId])
  @@index([stockDate])
  @@index([type])
}

