  service ServiceCatalogItem       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  stock   ServiceAvailabilityStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([serviceId])
  @@index([stockId])
  @@index([type])
  @@index([serviceRequestId])
