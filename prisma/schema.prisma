generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HOTEL_ADMIN
  STAFF
  KITCHEN
}

enum ServiceBillingMode {
  FREE
  FIXED_PRICE
  PRICE_ON_CONFIRMATION
}

enum TagType {
  ROOM
  POOL
  RESTAURANT
  LOBBY
  AMENITY
  SPA
  PARKING
  GYM
  BAR
  OTHER
}

enum TagStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  ROOM_CHARGE
  PAY_AT_COUNTER
  CASH
  POS
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum ServiceRequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceRequestAttachmentType {
  GUEST_UPLOAD
  STAFF_BEFORE
  STAFF_AFTER
  INTERNAL_NOTE
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  ORDER_DEDUCTION
}

enum PosSyncStatus {
  PENDING
  SENT
  FAILED
  RETRY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum MenuProductType {
  SINGLE
  BUNDLE
}

enum OrderItemStatus {
  ACTIVE
  PARTIALLY_CANCELLED
  CANCELLED
}

enum DashboardModule {
  OVERVIEW
  HOTELS
  HOTEL_GUIDE
  ROOMS_LOCATIONS
  NFC_TAGS
  MENU
  INVENTORY
  GUEST_STAYS
  ORDERS
  KITCHEN_DISPLAY
  SERVICES_MODULE
  SERVICE_REQUESTS
  POS_TERMINAL
  ANALYTICS
  REPORTS
  HOTEL_SETTINGS
  USER_ACCOUNT_SETTINGS
  REWARDS
}

enum GuestPointLedgerType {
  EARNED
  REDEEMED
  ADJUSTED
  VOIDED
  EXPIRED
  REFUNDED
  BONUS
}

enum GuestStayStatus {
  ACTIVE
  CHECKED_OUT
  CANCELLED
  EXPIRED
}

enum GuestStayCheckoutPaymentMethod {
  CASH
  CARD
  GCASH
  MAYA
  QRPH
  BANK_TRANSFER
  COMPANY_ACCOUNT
  COMPLIMENTARY
  WAIVED
  PAY_LATER
}

enum GuestStayFolioStatus {
  OPEN
  CLOSED
  VOIDED
}

enum GuestStayFolioLineType {
  FOOD_ORDER
  SERVICE_CHARGE
  MANUAL_CHARGE
  DISCOUNT
}

enum GuestStayFolioLineStatus {
  POSTED
  VOIDED
}

enum GuestStayFolioPaymentStatus {
  POSTED
  VOIDED
  REFUNDED
}

enum GuestPointLedgerStatus {
  PENDING
  CONFIRMED
  VOIDED
}

enum RewardType {
  DISCOUNT_AMOUNT
  DISCOUNT_PERCENT
  FREE_ITEM
  CUSTOM
}

enum RewardRedemptionStatus {
  RESERVED
  USED
  CANCELLED
  EXPIRED
}

enum FulfillmentTiming {
  ASAP
  SCHEDULED
}

enum ScheduledReleaseStatus {
  NOT_SCHEDULED
  SCHEDULED
  RELEASED
  CANCELLED
  EXPIRED
  FAILED
}

enum SeriesCodeType {
  FOOD
  SERVICE
}

model SeriesCodeCounter {
  id String @id @default(cuid())

  prefix String         @db.VarChar(16)
  type   SeriesCodeType

  nextNumber Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prefix, type])
  @@index([prefix])
}

model UserDashboardPermission {
  id     String          @id @default(cuid())
  userId String
  module DashboardModule

  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@index([module])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  hotelId      String?
  hotel        Hotel?   @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedServiceRequests           ServiceRequest[]              @relation("AssignedRequests")
  orderStatusUpdates                OrderStatusHistory[]
  serviceStatusUpdates              ServiceRequestStatusHistory[]
  inventoryMovements                InventoryMovement[]
  activityLogs                      ActivityLog[]
  dashboardPermissions              UserDashboardPermission[]
  createdGuestPointLedgers          GuestPointLedger[]            @relation("GuestPointLedgerCreatedBy")
  uploadedServiceRequestAttachments ServiceRequestAttachment[]    @relation("ServiceRequestAttachmentUploadedBy")
  createdGuestStayFolios            GuestStayFolio[]              @relation("GuestStayFolioCreatedBy")
  closedGuestStayFolios             GuestStayFolio[]              @relation("GuestStayFolioClosedBy")
  postedGuestStayFolioLines         GuestStayFolioLine[]          @relation("GuestStayFolioLinePostedBy")
  receivedGuestStayFolioPayments    GuestStayFolioPayment[]       @relation("GuestStayFolioPaymentReceivedBy")

  @@index([hotelId])
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  brandColor  String   @default("#111111")
  accentColor String   @default("#B88938")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings                     HotelSettings?
  users                        User[]
  rooms                        Room[]
  locations                    Location[]
  nfcTags                      NfcTag[]
  menuCategories               MenuCategory[]
  menuProducts                 MenuProduct[]
  inventoryItems               InventoryItem[]
  inventoryMovements           InventoryMovement[]
  orders                       Order[]
  serviceRequests              ServiceRequest[]
  posIntegration               PosIntegration?
  activityLogs                 ActivityLog[]
  nfcAccessSessions            NfcAccessSession[]
  subscription                 HotelSubscription?
  serviceCatalogItems          ServiceCatalogItem[]
  guideSections                HotelGuideSection[]
  guideItems                   HotelGuideItem[]
  menuDailyStocks              MenuDailyStock[]
  menuDailyStockMovements      MenuDailyStockMovement[]
  menuAvailabilityStocks       MenuAvailabilityStock[]
  menuAvailabilityMovements    MenuAvailabilityMovement[]
  menuBundleComponents         MenuBundleComponent[]
  serviceAvailabilityStocks    ServiceAvailabilityStock[]
  serviceAvailabilityMovements ServiceAvailabilityMovement[]
  serviceRequestAttachments    ServiceRequestAttachment[]
  guestMembers                 GuestMember[]
  guestStays                   GuestStay[]
  guestPointAccounts           GuestPointAccount[]
  guestPointLedgers            GuestPointLedger[]
  rewards                      Reward[]
  rewardRedemptions            RewardRedemption[]
  guestPointSettings           GuestPointSettings?

  guideImages            HotelGuideImage[]
  nfcGuestSessions       NfcGuestSession[]
  guestStayFolios        GuestStayFolio[]
  guestStayFolioLines    GuestStayFolioLine[]
  guestStayFolioPayments GuestStayFolioPayment[]
}

model HotelSettings {
  id      String @id @default(cuid())
  hotelId String @unique
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  currency          String  @default("PHP")
  taxRate           Decimal @default(0.00) @db.Decimal(6, 4)
  serviceChargeRate Decimal @default(0.00) @db.Decimal(6, 4)

  wifiName                String?
  wifiPassword            String?
  checkInTime             String  @default("2:00 PM")
  checkOutTime            String  @default("12:00 PM")
  poolHours               String  @default("7:00 AM - 9:00 PM")
  poolRules               String? @db.Text
  policies                String? @db.Text
  guideText               String? @db.Text
  contactPhone            String?
  contactEmail            String?
  guestPortalHeroImageUrl String? @db.Text

  nfcRoomPasscodeEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id        String    @id @default(cuid())
  hotelId   String
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  number    String
  floor     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  nfcTags          NfcTag[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  nfcGuestSessions NfcGuestSession[]
  guestStays       GuestStay[]

  @@unique([hotelId, number])
  @@index([hotelId])
}

model Location {
  id          String    @id @default(cuid())
  hotelId     String
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  type        TagType
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  nfcTags          NfcTag[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  nfcGuestSessions NfcGuestSession[]

  @@index([hotelId])
}

model NfcTag {
  id            String    @id @default(cuid())
  hotelId       String
  hotel         Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  code          String    @unique
  label         String
  tagType       TagType
  status        TagStatus @default(ACTIVE)
  roomId        String?
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scanSecret    String?   @unique
  lastScannedAt DateTime?
  deletedAt     DateTime?

  accessSessions NfcAccessSession[]

  orders          Order[]
  serviceRequests ServiceRequest[]
  guestSessions   NfcGuestSession[]

  @@index([hotelId])
  @@index([roomId])
  @@index([locationId])
}

model MenuCategory {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MenuProduct[]

  @@index([hotelId])
}

model MenuProduct {
  id         String       @id @default(cuid())
  hotelId    String
  hotel      Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  categoryId String
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name            String
  description     String? @db.Text
  priceCents      Int
  imageUrl        String?
  isAvailable     Boolean @default(true)
  prepTimeMinutes Int     @default(10)

  productType MenuProductType @default(SINGLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     ProductImage[]
  recipes    ProductInventoryRecipe[]
  orderItems OrderItem[]

  dailyStocks         MenuDailyStock[]
  dailyStockMovements MenuDailyStockMovement[]

  availabilityStocks    MenuAvailabilityStock[]
  availabilityMovements MenuAvailabilityMovement[]

  bundleComponents MenuBundleComponent[] @relation("BundleProduct")
  usedInBundles    MenuBundleComponent[] @relation("BundleComponentProduct")

  orderBundleProducts          OrderItemBundleComponent[] @relation("OrderBundleProduct")
  orderBundleComponentProducts OrderItemBundleComponent[] @relation("OrderBundleComponentProduct")

  @@index([hotelId])
  @@index([categoryId])
  @@index([productType])
}

model MenuBundleComponent {
  id                 String @id @default(cuid())
  hotelId            String
  bundleProductId    String
  componentProductId String
  quantity           Int    @default(1)
  sortOrder          Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel            Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bundleProduct    MenuProduct @relation("BundleProduct", fields: [bundleProductId], references: [id], onDelete: Cascade)
  componentProduct MenuProduct @relation("BundleComponentProduct", fields: [componentProductId], references: [id], onDelete: Cascade)

  @@unique([bundleProductId, componentProductId])
  @@index([hotelId])
  @@index([bundleProductId])
  @@index([componentProductId])
}

model ProductImage {
  id        String      @id @default(cuid())
  productId String
  product   MenuProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
}

model InventoryItem {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  unit          String
  stockQuantity Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel  Decimal  @default(0) @db.Decimal(12, 3)
  supplier      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements InventoryMovement[]
  recipes   ProductInventoryRecipe[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  hotelId   String
  hotel     Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  itemId    String
  item      InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Decimal               @db.Decimal(12, 3)
  reason    String?
  orderId   String?
  order     Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime              @default(now())

  @@index([hotelId])
  @@index([itemId])
  @@index([orderId])
}

enum ServiceAvailabilityMovementType {
  SET_STOCK
  ADD_STOCK
  REMOVE_STOCK
  SOLD_OUT
  REOPEN
  REQUEST_DEDUCTION
  CANCEL_RESTORE
}

model ProductInventoryRecipe {
  id              String        @id @default(cuid())
  productId       String
  product         MenuProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Decimal       @db.Decimal(12, 3)

  @@unique([productId, inventoryItemId])
}

model Order {
  id                  String        @id @default(cuid())
  hotelId             String
  hotel               Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId              String?
  room                Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId          String?
  location            Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tagId               String?
  tag                 NfcTag?       @relation(fields: [tagId], references: [id], onDelete: SetNull)
  orderCode           String        @unique
  guestName           String?
  notes               String?       @db.Text
  paymentMethod       PaymentMethod @default(ROOM_CHARGE)
  paymentStatus       PaymentStatus @default(UNPAID)
  status              OrderStatus   @default(PENDING)
  subtotalCents       Int
  serviceChargeCents  Int           @default(0)
  taxCents            Int           @default(0)
  totalCents          Int
  posSyncStatus       PosSyncStatus @default(PENDING)
  inventoryDeductedAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  items               OrderItem[]
  guestStayFolioLines GuestStayFolioLine[]
  statusHistory       OrderStatusHistory[]
  posLogs             PosSyncLog[]
  inventoryMovements  InventoryMovement[]
  guestSessionId      String?
  guestSession        NfcGuestSession?     @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  guestMemberId       String?
  guestMember         GuestMember?         @relation(fields: [guestMemberId], references: [id], onDelete: SetNull)

  guestStayId String?
  guestStay   GuestStay? @relation(fields: [guestStayId], references: [id], onDelete: SetNull)

  fulfillmentTiming FulfillmentTiming @default(ASAP)

  scheduledFor         DateTime?
  scheduledWindowStart DateTime?
  scheduledWindowEnd   DateTime?

  releaseAt  DateTime?
  releasedAt DateTime?

  scheduledReleaseStatus ScheduledReleaseStatus @default(NOT_SCHEDULED)
  scheduledNote          String?                @db.Text

  @@index([guestSessionId])
  @@index([guestMemberId])
  @@index([hotelId])
  @@index([status])
  @@index([createdAt])
  @@index([guestStayId])
  @@index([fulfillmentTiming])
  @@index([scheduledFor])
  @@index([releaseAt])
  @@index([releasedAt])
  @@index([scheduledReleaseStatus])
  @@index([hotelId, fulfillmentTiming])
  @@index([hotelId, scheduledReleaseStatus])
  @@index([hotelId, releaseAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   MenuProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productNameSnapshot String
  quantity            Int
  unitPriceCents      Int
  notes               String? @db.Text

  isBundleSnapshot Boolean @default(false)

  createdAt DateTime @default(now())

  bundleComponents OrderItemBundleComponent[]
  status           OrderItemStatus            @default(ACTIVE)
  cancelledQty     Int                        @default(0)
  cancelledAt      DateTime?
  cancelReason     String?
  cancelledById    String?

  @@index([orderId])
  @@index([productId])
  @@index([isBundleSnapshot])
}

model OrderItemBundleComponent {
  id          String @id @default(cuid())
  orderItemId String

  bundleProductId    String?
  componentProductId String?

  componentNameSnapshot String
  quantity              Int

  createdAt DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  bundleProduct MenuProduct? @relation("OrderBundleProduct", fields: [bundleProductId], references: [id], onDelete: SetNull)

  componentProduct MenuProduct? @relation("OrderBundleComponentProduct", fields: [componentProductId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([bundleProductId])
  @@index([componentProductId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model ServiceRequest {
  id            String               @id @default(cuid())
  hotelId       String
  hotel         Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId        String?
  room          Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  locationId    String?
  location      Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tagId         String?
  tag           NfcTag?              @relation(fields: [tagId], references: [id], onDelete: SetNull)
  requestCode   String
  type          String
  guestName     String?
  notes         String?              @db.Text
  status        ServiceRequestStatus @default(NEW)
  assignedToId  String?
  assignedTo    User?                @relation("AssignedRequests", fields: [assignedToId], references: [id], onDelete: SetNull)
  quantity      Int                  @default(1)
  cancelledQty  Int                  @default(0)
  cancelledAt   DateTime?
  cancelReason  String?
  cancelledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guestStayId String?
  guestStay   GuestStay? @relation(fields: [guestStayId], references: [id], onDelete: SetNull)

  statusHistory  ServiceRequestStatusHistory[]
  attachments    ServiceRequestAttachment[]
  guestSessionId String?
  guestSession   NfcGuestSession?              @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  guestMemberId String?
  guestMember   GuestMember? @relation(fields: [guestMemberId], references: [id], onDelete: SetNull)

  fulfillmentTiming FulfillmentTiming @default(ASAP)

  scheduledFor         DateTime?
  scheduledWindowStart DateTime?
  scheduledWindowEnd   DateTime?

  releaseAt  DateTime?
  releasedAt DateTime?

  scheduledReleaseStatus ScheduledReleaseStatus @default(NOT_SCHEDULED)
  scheduledNote          String?                @db.Text

  @@index([guestSessionId])
  @@index([guestMemberId])
  @@index([hotelId])
  @@index([status])
  @@index([requestCode])
  @@index([hotelId, requestCode])
  @@index([guestStayId])
  @@index([fulfillmentTiming])
  @@index([scheduledFor])
  @@index([releaseAt])
  @@index([releasedAt])
  @@index([scheduledReleaseStatus])
  @@index([hotelId, fulfillmentTiming])
  @@index([hotelId, scheduledReleaseStatus])
  @@index([hotelId, releaseAt])
}

model ServiceRequestAttachment {
  id String @id @default(cuid())

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  requestId String?
  request   ServiceRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  requestCode String?

  imageUrl     String  @db.Text
  originalName String?
  mimeType     String
  sizeBytes    Int

  caption String? @db.Text

  attachmentType ServiceRequestAttachmentType @default(GUEST_UPLOAD)

  uploadedById String?
  uploadedBy   User?   @relation("ServiceRequestAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  uploadedByGuest Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([hotelId])
  @@index([requestId])
  @@index([requestCode])
  @@index([attachmentType])
  @@index([uploadedById])
}

model ServiceRequestStatusHistory {
  id        String               @id @default(cuid())
  requestId String
  request   ServiceRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status    ServiceRequestStatus
  note      String?
  userId    String?
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime             @default(now())

  @@index([requestId])
}

model PosIntegration {
  id              String   @id @default(cuid())
  hotelId         String   @unique
  hotel           Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  providerName    String   @default("Mock POS")
  apiEndpoint     String?
  apiKeyEncrypted String?
  webhookSecret   String?
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs PosSyncLog[]
}

model PosSyncLog {
  id              String        @id @default(cuid())
  hotelId         String
  orderId         String
  integrationId   String?
  status          PosSyncStatus
  requestPayload  Json?
  responsePayload Json?
  error           String?       @db.Text
  createdAt       DateTime      @default(now())

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  integration PosIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  hotelId   String?
  hotel     Hotel?   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actor     String?
  action    String
  entity    String
  entityId  String?
  message   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([hotelId])
  @@index([createdAt])
}

model SubscriptionPackage {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  priceCents  Int
  maxHotels   Int      @default(1)
  maxRooms    Int      @default(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions HotelSubscription[]
}

model HotelSubscription {
  id        String              @id @default(cuid())
  hotelId   String              @unique
  hotel     Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  packageId String
  package   SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  status    SubscriptionStatus  @default(TRIALING)
  startedAt DateTime            @default(now())
  endsAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model NfcAccessSession {
  id            String  @id @default(cuid())
  tagId         String
  hotelId       String
  tokenHash     String  @unique
  userAgentHash String?
  ipHash        String?

  expiresAt     DateTime
  idleExpiresAt DateTime?
  lastSeenAt    DateTime?

  revokedAt DateTime?
  createdAt DateTime  @default(now())

  tag   NfcTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  hotel Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@index([hotelId])
  @@index([expiresAt])
  @@index([idleExpiresAt])
}

model NfcGuestSession {
  id         String  @id @default(cuid())
  sessionKey String  @unique
  hotelId    String
  tagId      String
  roomId     String?
  locationId String?

  guestMemberId String?

  startedAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  endedAt    DateTime?

  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  tag         NfcTag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  room        Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  location    Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  guestMember GuestMember? @relation(fields: [guestMemberId], references: [id], onDelete: SetNull)

  orders          Order[]
  serviceRequests ServiceRequest[]

  guestStayId String?
  guestStay   GuestStay? @relation(fields: [guestStayId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([tagId])
  @@index([roomId])
  @@index([locationId])
  @@index([guestMemberId])
  @@index([startedAt])
  @@index([guestStayId])
}

model RoomAddOnCharge {
