  updatedAt  DateTime @updatedAt

  guestStayFolioLines GuestStayFolioLine[]

  @@index([hotelId])
  @@index([roomId])
  @@index([serviceRequestId])
  @@index([paymentStatus])
  @@index([paidAt])
}

enum RoomAddOnPaymentStatus {
  UNPAID
  PAID
  VOIDED
}

model ServiceCatalogItem {
